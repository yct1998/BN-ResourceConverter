"statistics."

#: .\main.lua
msgid "价格规则:"
msgstr "Pricing rules:"

#: .\main.lua
msgid "- 目录中保存的是提取到的基础价格。"
msgstr "- The base price stored in the catalog is the extracted base price."

#: .\main.lua
msgid "- 实际回收价 = 基础价格 × 回收倍率"
msgstr "- Actual recycle price = Base price × Recycle multiplier"

#: .\main.lua
msgid "- 实际转换价 = 基础价格 × 转换倍率"
msgstr "- Actual conversion price = Base price × Conversion multiplier"

#: .\main.lua
msgid "- 未收录或价格为 0 的物品，回收保底按 $0.01 处理"
msgstr ""
"- Items not listed or with price 0 are guaranteed a minimum recycle value of"
" $0.01"

#: .\main.lua
msgid "- 默认回收倍率 = 0.50"
msgstr "- Default recycle multiplier = 0.50"

#: .\main.lua
msgid "- 默认转换倍率 = 2.00"
msgstr "- Default conversion multiplier = 2.00"

#: .\main.lua
